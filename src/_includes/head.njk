<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ pageDescription or site.description }}" />
  <meta property="og:title" content="{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.title }}" />
  <meta property="og:description" content="{{ pageDescription or site.description }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta name="theme-color" content="#0f172a" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/hozo.css" />
</head>
