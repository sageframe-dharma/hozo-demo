---
layout: base.njk
permalink: /demo/jobs/new/
pageTitle: "New Job"
isEdit: false
---

{% macro field(label, name, value, type, placeholder, required, hint) %}
  <div>
    <label class="text-xs text-slate-400 block mb-1">
      {{ label }}{% if required %} <span class="text-red-400">*</span>{% endif %}
    </label>
    <input type="{{ type or 'text' }}" name="{{ name }}"
           value="{{ value or '' }}"
           {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
           {% if required %}required{% endif %}
           class="w-full bg-slate-800 border border-slate-600 rounded px-3 py-2 text-sm focus:outline-none focus:border-blue-400"/>
    {% if hint %}<p class="text-slate-600 text-xs mt-1">{{ hint }}</p>{% endif %}
  </div>
{% endmacro %}

{% macro checkbox(label, name, checked, hint) %}
  <div>
    <div class="flex items-center gap-2">
      <input type="checkbox" name="{{ name }}" id="{{ name }}"
             {% if checked %}checked{% endif %}
             class="accent-blue-500"/>
      <label for="{{ name }}" class="text-sm text-slate-300">{{ label }}</label>
    </div>
    {% if hint %}<p class="text-slate-600 text-xs mt-0.5 ml-5">{{ hint }}</p>{% endif %}
  </div>
{% endmacro %}

<div class="flex items-center gap-4 mb-6">
  <a href="/demo/dashboard/" class="text-slate-400 text-sm hover:text-slate-200">← Back</a>
  <h1 class="text-2xl font-bold">New Job</h1>
</div>

<form method="post" action="#" class="space-y-6">

  <!-- Core -->
  <div class="card p-5">
    <h2 class="font-semibold text-slate-300 mb-4 text-sm uppercase tracking-wide">Job</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="text-xs text-slate-400 block mb-1">Job name <span class="text-red-400">*</span></label>
        <input type="text" name="name"
               value=""
               placeholder="weekly"
               required
               class="w-full bg-slate-800 border border-slate-600 rounded px-3 py-2 text-sm focus:outline-none focus:border-blue-400"/>
      </div>
      {{ field('Description', 'description', '', 'text', 'e.g. Weekly backup of home data', false, '') }}
    </div>
  </div>

  <!-- Source / Target -->
  <div class="card p-5">
    <h2 class="font-semibold text-slate-300 mb-4 text-sm uppercase tracking-wide">Source &amp; Target</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {{ field('Source ZFS dataset', 'source_dataset', '', 'text', 'rpool/data', true, '') }}
      {{ field('Target host', 'target_host', '', 'text', 'backup-box.tailnet.ts.net', true, '') }}
      {{ field('Target ZFS dataset', 'target_dataset', '', 'text', 'backup/home-data', true, '') }}
      {{ field('MAC address (Wake-on-LAN)', 'mac_address', '', 'text', 'AA:BB:CC:DD:EE:FF', true, '') }}
    </div>
  </div>

  <!-- Schedule -->
  <div class="card p-5">
    <h2 class="font-semibold text-slate-300 mb-4 text-sm uppercase tracking-wide">Schedule</h2>
    {{ field('Schedule', 'schedule', '', 'text', 'weekly Sunday 03:00  or  daily 02:30', false,
             'Leave blank for manual-only jobs. Format: "weekly &lt;Day&gt; HH:MM" or "daily HH:MM" (UTC).') }}
  </div>

  <!-- SSH -->
  <div class="card p-5">
    <h2 class="font-semibold text-slate-300 mb-4 text-sm uppercase tracking-wide">SSH</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {{ field('SSH user', 'ssh_user', 'root', 'text', '', false, '') }}
      {{ field('SSH port', 'ssh_port', '22', 'number', '', false, '') }}
      {{ field('SSH key path', 'ssh_key', '', 'text', '~/.ssh/id_ed25519  (leave blank for agent)', false,
               'Path on the machine running Hōzō.') }}
    </div>
  </div>

  <!-- Behaviour -->
  <div class="card p-5">
    <h2 class="font-semibold text-slate-300 mb-4 text-sm uppercase tracking-wide">Behaviour</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      {{ field('SSH wait timeout (s)', 'ssh_timeout', '120', 'number', '', false, '') }}
      {{ field('Retries', 'retries', '3', 'number', '', false, '') }}
      {{ field('Retry delay (s)', 'retry_delay', '60', 'number', '', false, '') }}
      {{ field('WOL broadcast IP', 'wol_broadcast', '255.255.255.255', 'text', '', false, '') }}
    </div>
    <div class="space-y-2">
      {{ checkbox('Recursive (replicate child datasets)', 'recursive', true, '') }}
      {{ checkbox('Shutdown remote host after backup', 'shutdown_after', true,
                  'Powers the box off over SSH when the backup finishes. Leave unchecked if the box runs 24/7.') }}
      {{ checkbox('No privilege elevation (skip sudo on syncoid)', 'no_privilege_elevation', false, '') }}
    </div>
  </div>

  <!-- Drive Spin-Up -->
  <div class="card p-5">
    <h2 class="font-semibold text-slate-300 mb-1 text-sm uppercase tracking-wide">Drive Spin-Up</h2>
    <p class="text-slate-500 text-xs mb-4">
      For NUC / mini-PC backup targets with an external USB or SATA drive that
      spins down when idle. Hōzō will issue a read-kick and wait before syncing.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {{ field('Backup drive device', 'backup_device', '', 'text',
               '/dev/sdb  (leave blank if not applicable)',
               false,
               'Block device on the remote box. Hōzō wakes a spun-down drive over SSH before syncing (it does not spin it down — configure that on the box).') }}
      {{ field('Spin-up timeout (s)', 'disk_spinup_timeout', '90', 'number', '', false, '') }}
    </div>
  </div>

  <div class="flex gap-3">
    <button type="submit"
            class="btn-primary px-6 py-2.5 rounded text-white text-sm font-semibold cursor-pointer">
      Create Job
    </button>
    <a href="/demo/dashboard/" class="text-slate-400 text-sm px-4 py-2.5">Cancel</a>
  </div>

</form>

<script>
  document.querySelector("form").addEventListener("submit", (e) => {
    e.preventDefault();
    const name = (new FormData(e.target).get("name") || "this job").trim();
    hozoToast(`(demo) Job '${name}' would be ${"created"}.`, "ok");
    setTimeout(() => { window.location.href = "/demo/dashboard/"; }, 900);
  });
</script>
